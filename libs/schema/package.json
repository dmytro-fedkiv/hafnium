{
  "name": "@hafnium/schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@livestore/livestore": "0.3.1"
  },
  "nx": {
    "name": "schema",
    "targets": {
      "build": {
        "command": "tsc -p tsconfig.json --noEmit",
        "options": {
          "cwd": "libs/schema"
        }
      },
      "typecheck": {
        "command": "tsc -p tsconfig.json --noEmit",
        "options": {
          "cwd": "libs/schema"
        }
      },
      "test": {
        "command": "vitest run --passWithNoTests",
        "options": {
          "cwd": "libs/schema"
        }
      },
      "lint": {
        "command": "eslint .",
        "options": {
          "cwd": "libs/schema"
        }
      }
    }
  }
}
