{
  "name": "@hafnium/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@livestore/livestore": "0.4.0-dev.22",
    "effect": "3.19.12"
  },
  "nx": {
    "name": "engine",
    "targets": {
      "build": {
        "command": "tsc -p tsconfig.json --noEmit",
        "options": {
          "cwd": "libs/engine"
        }
      },
      "typecheck": {
        "command": "tsc -p tsconfig.json --noEmit",
        "options": {
          "cwd": "libs/engine"
        }
      },
      "test": {
        "command": "vitest run --passWithNoTests",
        "options": {
          "cwd": "libs/engine"
        }
      },
      "lint": {
        "command": "eslint .",
        "options": {
          "cwd": "libs/engine"
        }
      }
    }
  }
}
