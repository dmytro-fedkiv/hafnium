{
  "name": "hafnium",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "type": "module",
  "scripts": {
    "dev:web": "vp run --filter @hafnium/web dev",
    "build": "vp run -r build",
    "check": "vp run -r check",
    "fmt": "vp run -r fmt",
    "lint": "vp run -r lint",
    "test": "vp run -r test",
    "typecheck": "vp run -r typecheck"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "vite-plus": "latest"
  },
  "packageManager": "bun@1.3.13"
}
