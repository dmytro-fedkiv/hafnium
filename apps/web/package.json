{
  "name": "@hafnium/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hafnium/schema": "workspace:*",
    "@livestore/adapter-web": "0.3.1",
    "@livestore/livestore": "0.3.1",
    "@livestore/peer-deps": "0.3.1",
    "@livestore/react": "0.3.1",
    "@livestore/wa-sqlite": "1.0.5-dev.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-table": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@livestore/devtools-vite": "0.3.1",
    "@tailwindcss/vite": "latest",
    "@vitejs/plugin-react": "latest",
    "tailwindcss": "latest",
    "tw-animate-css": "^1.4.0",
    "vite": "latest"
  },
  "nx": {
    "name": "web",
    "targets": {
      "dev": {
        "command": "vite dev",
        "options": {
          "cwd": "apps/web"
        }
      },
      "build": {
        "command": "vite build",
        "options": {
          "cwd": "apps/web"
        }
      },
      "typecheck": {
        "command": "tsc -p tsconfig.json --noEmit",
        "options": {
          "cwd": "apps/web"
        }
      },
      "test": {
        "command": "vitest run --passWithNoTests",
        "options": {
          "cwd": "apps/web"
        }
      },
      "lint": {
        "command": "eslint .",
        "options": {
          "cwd": "apps/web"
        }
      }
    }
  }
}
